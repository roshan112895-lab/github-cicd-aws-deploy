{
  "name": "taskflow",
  "version": "1.0.0",
  "description": "Task management app with REST API, web UI, PostgreSQL, Supabase, and EC2 deployment via GitHub Actions",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "start:dev": "nodemon src/server.js",
    "dev": "node --watch src/server.js",
    "migrate:postgres": "node scripts/migrate-json-to-postgres.js",
    "migrate:supabase": "node scripts/migrate-supabase.js",
    "db:check": "node scripts/check-db.js",
    "db:check:supabase": "node scripts/check-db-supabase.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "task-management",
    "nodejs",
    "express",
    "docker",
    "aws",
    "github-actions"
  ],
  "license": "MIT",
  "dependencies": {
    "dotenv": "^17.4.2",
    "express": "^4.21.2",
    "pg": "^8.21.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  }
}
